<?xml version="1.0" encoding="UTF-8"?>
<!--
  Live Poll — PowerPoint content add-in manifest.

  BEFORE USING: replace every "proceduralist.github.io/live-poll"
  below with your real GitHub Pages address (README step 3).
-->
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:type="ContentApp">

  <Id>1383b74e-1aaf-40d8-9653-3b16b5f349a3</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>Ryan Fredette</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="Live Poll" />
  <Description DefaultValue="Live audience polling: the audience scans a QR code, votes on their phones, and results appear on the slide in real time." />
  <IconUrl DefaultValue="https://proceduralist.github.io/live-poll/assets/icon-32.png" />
  <HighResolutionIconUrl DefaultValue="https://proceduralist.github.io/live-poll/assets/icon-64.png" />
  <SupportUrl DefaultValue="https://github.com/proceduralist/live-poll" />

  <Hosts>
    <Host Name="Presentation" />
  </Hosts>

  <DefaultSettings>
    <SourceLocation DefaultValue="https://proceduralist.github.io/live-poll/widget.html" />
    <RequestedWidth>820</RequestedWidth>
    <RequestedHeight>440</RequestedHeight>
  </DefaultSettings>

  <Permissions>ReadWriteDocument</Permissions>
</OfficeApp>
